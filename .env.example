# Vision-language model (OpenAI-compatible endpoint)
GPT_API_KEY=replace-me
GPT_BASE_URL=https://api.example.com/v1
GPT_MODEL=replace-with-model-id

# Image editing API
TOAPIS_API_KEY=replace-me
TOAPIS_BASE_URL=https://api.example.com
TOAPIS_API_URL=https://api.example.com/v1/images/generations
TOAPIS_UPLOAD_URL=https://api.example.com/v1/uploads/images
TOAPIS_MODEL=gpt-image-2
TOAPIS_RESOLUTION=4k

# Optional Alibaba Cloud OSS transport
OSS_ACCESS_KEY_ID=replace-me
OSS_ACCESS_KEY_SECRET=replace-me
OSS_BUCKET_NAME=replace-with-bucket
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_PATH_PREFIX=CASCADEFORGE_EDIT
OSS_SIGN_EXPIRES=3600
